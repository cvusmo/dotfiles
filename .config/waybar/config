{
  "layer": "top",
  "position": "top",
  "height": 54,
  "modules-center": ["custom/playerctl", "custom/spotify", "custom/weather", "custom/hyprclock", "wlr/taskbar"],
  "modules-right": ["pulseaudio", "network", "custom/cpu-usage", "custom/gpu-usage", "custom/disk-usage", "custom/volume_control"],
  "modules-left": ["custom/arch", "hyprland/workspaces"],
  
  "custom/arch": {
    "format": "∩à╝",
    "on-click": "python3 ~/.config/waybar/scripts/launch_wofi.py"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "disable-scroll": true,
    "show-back-and-forth": true,
    "persistent-workspaces": {
      "0": true,
      "1": true,
      "2": true,
      "3": true,
      "4": true,
      "5": true
    },
    "show-special": false,
    "format-icons": {
      "0": "∩Çò",
      "1": "εÜ«",
      "2": "≤░ê╣",
      "3": "∩ç┐i",
      "4": "≤░ê╣",
      "5": "∩å╝",
      "6": "∩î╕",
      "7": "≤░é½",
      "8": "∩å│",
      "9": "≤░öƒ",
      "10": "≤░ƒó",
      "11": "11",
      "12": "12",
      "13": "13",
      "14": "14",
      "15": "15",
      "16": "16",
      "17": "17",
      "18": "18",
      "19": "19",
      "20": "20"
    }
  },

  "custom/playerctl": {
    "format": "  {0}  ",
    "exec": "python3 ~/.config/waybar/scripts/mediaplayer.py",
    "on-click": "python3 ~/.config/waybar/scripts/mediaplayer.py toggle",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "interval": 1,
    "format-icons": {
      "Paused": "∩üï",
      "Playing": "∩üî"
    }
  },

  "custom/spotify": {
    "format": "  {0}  ",
    "exec": "python3 ~/.config/waybar/scripts/spotify.py",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "interval": 1
  },

  "custom/weather": {
    "format": "{text}",
    "exec": "python3 ~/.config/waybar/scripts/weather.py",
    "interval": 300,
    "return-type": "json"
  },

  "custom/hyprclock": {
    "format": "{text}",
    "tooltip": true,
    "exec": "python3 ~/.config/waybar/scripts/hyprclock.py",
    "return-type": "json",
    "interval": 1,
    "on-click": "/home/echo/projects/remote/hyprclock/target/release/hyprclock",
  },

  "custom/volume_control": {
    "format": "  ∩Ç¿ {0}%%  ",
    "exec": "python3 ~/.config/hypr/scripts/volume_control.py status",
    "on-click": "python3 ~/.config/hypr/scripts/volume_control.py mute",
    "on-scroll-up": "python3 ~/.config/hypr/scripts/volume_control.py increase 2",
    "on-scroll-down": "python3 ~/.config/hypr/scripts/volume_control.py decrease 2"
  },

  "wlr/taskbar": {
    "icon-size": 18,
    "on-click": "activate",
    "on-click-right": "minimize",
    "format": "  {icon}  "
  },

  "pulseaudio": {
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format": "  ∩Ç¿ {volume}%%  ",
    "format-muted": "  ∩èï  ",
    "format-icons": {
      "headphone": "∩ÇÑ",
      "hands-free": "∩èö",
      "headset": "∩ÇÑ",
      "phone": "∩éò",
      "portable": "∩éò",
      "car": "∩å╣",
      "default": ["∩⌐┐", "∩⌐╜"]
    },
    "on-click-right": "pavucontrol"
  },

  "network": {
    "interval": 2,
    "format-wifi": "∩ç½",
    "format-ethernet": "∩₧û",
    "format-linked": "{ifname} {essid}",
    "format-disconnected": "∩ü₧",
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}\n∩äâ {bandwidthDownBits}\n∩äé {bandwidthUpBits}",
    "on-click-right": "python3 ~/.config/waybar/scripts/show_public_ip.py",
    "class": {
      "wifi": "network-connected",
      "ethernet": "network-connected",
      "disconnected": "network-disconnected"
    }
  },

  "custom/cpu-usage": {
    "format": "{text}",
    "exec": "python3 ~/.config/waybar/scripts/cpu_usage.py",
    "interval": 2
  },

  "custom/gpu-usage": {
    "format": "{text}",
    "exec": "python3 ~/.config/waybar/scripts/gpu_usage.py",
    "interval": 2
  },

  "custom/disk-usage": {
    "exec": "python3 ~/.config/waybar/scripts/diskusage.py",
    "interval": 600,
    "format": "  {text}  "
  }
}
